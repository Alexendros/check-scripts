{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Alexendros/check-scripts/main/skills/XEK_orquesta/schemas/finding.schema.json",
  "title": "xek/finding@v1",
  "description": "Salida JSON estructurada de cualquier skill XEK · merge por slug",
  "type": "object",
  "required": ["schema", "slug", "version", "timestamp", "modo", "exit_code"],
  "properties": {
    "schema":    { "type": "string", "const": "xek/finding@v1" },
    "slug":      { "type": "string", "pattern": "^XEK_[a-z0-9-]+$|^SINTESIS$" },
    "version":   { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "modo":      { "type": "string", "enum": ["dry-run", "sandbox", "real"] },
    "target":    { "type": "string" },
    "manifest_ref": { "type": "string", "description": "Path al manifiesto v2 consumido" },
    "exit_code": { "type": "integer", "enum": [0, 1, 2, 3, 4] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "message"],
        "properties": {
          "id":         { "type": "string" },
          "severity":   { "type": "string", "enum": ["info", "low", "medium", "high", "critical"] },
          "message":    { "type": "string" },
          "location":   { "type": "object", "properties": { "file": { "type": "string" }, "line": { "type": "integer" } } },
          "rule":       { "type": "string" },
          "cwe":        { "type": "string", "pattern": "^CWE-[0-9]+$" },
          "owasp":      { "type": "string" },
          "remediation":{ "type": "string" }
        }
      }
    },
    "propuesta": {
      "type": "object",
      "description": "Plan de corrección propuesto al operador (solo en modo real)",
      "properties": {
        "numero":    { "type": "integer" },
        "acciones":  { "type": "array", "items": { "type": "string" } },
        "estimacion_esfuerzo": { "type": "string", "enum": ["S", "M", "L", "XL"] }
      }
    },
    "skipped": {
      "type": "object",
      "description": "Si la skill se salta por aplicabilidad",
      "properties": {
        "razon": { "type": "string", "enum": ["not_applicable", "missing_dependency", "config_error", "override"] },
        "detalle": { "type": "string" }
      }
    }
  }
}
